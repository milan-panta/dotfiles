            "    auto v = _mm256_loadu_${3|ps,pd,si256|}(reinterpret_cast<const __m256${4|\\,d,i|}*>(src + i));",
            "    $0",
            "    _mm256_storeu_${3}(reinterpret_cast<__m256${4}*>(dst + i), v);",
            "  }",
            "  for (; i < n; ++i) {",
            "    dst[i] = src[i];",
            "  }",
            "}"
        ]
