    "mempool": {
        "prefix": "mempool",
        "description": "Fixed-size memory pool allocator",
        "body": [
            "template <typename T, std::size_t N>",
            "class MemPool {",
            "  union Slot {",
            "    T val;",
            "    Slot* next;",
            "    Slot() : next(nullptr) {}",
            "    ~Slot() {}",
            "  };",
            "",
            "  alignas(T) std::array<Slot, N> pool_;",
            "  Slot* free_ = nullptr;",
            "",
            " public:",
            "  MemPool() {",
            "    for (std::size_t i = 0; i < N; ++i) {",
            "      pool_[i].next = free_;",
            "      free_ = &pool_[i];",
            "    }",
            "  }",
            "",
            "  template <typename... Args>",
            "  T* alloc(Args&&... args) {",
            "    if (!free_) return nullptr;",
            "    auto* slot = free_;",
            "    free_ = slot->next;",
            "    return ::new (&slot->val) T(std::forward<Args>(args)...);",
            "  }",
            "",
            "  void dealloc(T* ptr) {",
            "    ptr->~T();",
            "    auto* slot = reinterpret_cast<Slot*>(ptr);",
            "    slot->next = free_;",
            "    free_ = slot;",
            "  }",
            "};",
            "$0"
        ]
    },
