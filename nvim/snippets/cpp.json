    "sock": {
        "prefix": "sock",
        "description": "UDP multicast socket setup (recv pattern)",
        "body": [
            "#include <arpa/inet.h>",
            "#include <netinet/in.h>",
            "#include <sys/socket.h>",
            "#include <unistd.h>",
            "",
            "int ${1:setup_multicast_recv}(const char* group, uint16_t port, const char* iface) {",
            "  int fd = socket(AF_INET, SOCK_DGRAM, 0);",
            "  if (fd < 0) return -1;",
            "",
            "  int reuse = 1;",
            "  setsockopt(fd, SOL_SOCKET, SO_REUSEADDR, &reuse, sizeof(reuse));",
            "",
            "  sockaddr_in addr{};",
            "  addr.sin_family = AF_INET;",
            "  addr.sin_port = htons(port);",
            "  addr.sin_addr.s_addr = htonl(INADDR_ANY);",
            "  if (bind(fd, reinterpret_cast<sockaddr*>(&addr), sizeof(addr)) < 0) {",
            "    close(fd);",
            "    return -1;",
            "  }",
            "",
            "  ip_mreq mreq{};",
            "  inet_pton(AF_INET, group, &mreq.imr_multiaddr);",
            "  inet_pton(AF_INET, iface, &mreq.imr_interface);",
            "  setsockopt(fd, IPPROTO_IP, IP_ADD_MEMBERSHIP, &mreq, sizeof(mreq));",
            "",
            "  $0",
            "  return fd;",
            "}"
        ]
    },
    "mpmc": {
        "prefix": "mpmc",
        "description": "Lock-free MPMC bounded queue (atomic CAS)",
        "body": [
            "template <typename T, std::size_t N>",
            "class MPMCQueue {",
            "  static_assert((N & (N - 1)) == 0, \"N must be power of 2\");",
            "  struct Slot {",
            "    std::atomic<std::size_t> turn{0};",
            "    T data;",
            "  };",
            "",
            "  alignas(64) std::atomic<std::size_t> head_{0};",
            "  alignas(64) std::atomic<std::size_t> tail_{0};",
            "  std::array<Slot, N> buf_;",
            "",
            " public:",
            "  MPMCQueue() {",
            "    for (std::size_t i = 0; i < N; ++i) buf_[i].turn.store(i, std::memory_order_relaxed);",
            "  }",
            "",
            "  bool try_push(const T& val) {",
            "    auto h = head_.load(std::memory_order_relaxed);",
            "    for (;;) {",
            "      auto& slot = buf_[h & (N - 1)];",
            "      auto turn = slot.turn.load(std::memory_order_acquire);",
            "      if (turn == h) {",
            "        if (head_.compare_exchange_weak(h, h + 1, std::memory_order_relaxed)) {",
            "          slot.data = val;",
            "          slot.turn.store(h + 1, std::memory_order_release);",
            "          return true;",
            "        }",
            "      } else if (turn < h) {",
            "        return false;",
            "      } else {",
            "        h = head_.load(std::memory_order_relaxed);",
            "      }",
            "    }",
            "  }",
            "",
            "  bool try_pop(T& val) {",
            "    auto t = tail_.load(std::memory_order_relaxed);",
            "    for (;;) {",
            "      auto& slot = buf_[t & (N - 1)];",
            "      auto turn = slot.turn.load(std::memory_order_acquire);",
            "      if (turn == t + 1) {",
            "        if (tail_.compare_exchange_weak(t, t + 1, std::memory_order_relaxed)) {",
            "          val = slot.data;",
            "          slot.turn.store(t + N, std::memory_order_release);",
            "          return true;",
            "        }",
            "      } else if (turn < t + 1) {",
            "        return false;",
            "      } else {",
            "        t = tail_.load(std::memory_order_relaxed);",
            "      }",
            "    }",
            "  }",
            "};",
            "$0"
        ]
    },
    "flatmap": {
        "prefix": "flatmap",
        "description": "Cache-friendly open-addressing flat hash map",
        "body": [
            "template <typename K, typename V, std::size_t N>",
            "class FlatMap {",
            "  enum State : uint8_t { Empty, Occupied, Deleted };",
            "  struct Entry {",
            "    K key;",
            "    V val;",
            "    State state = Empty;",
            "  };",
            "  std::array<Entry, N> table_{};",
            "  std::size_t size_ = 0;",
            "",
            "  static std::size_t hash(const K& k) { return std::hash<K>{}(k) & (N - 1); }",
            "",
            " public:",
            "  V* find(const K& k) {",
            "    for (auto i = hash(k);; i = (i + 1) & (N - 1)) {",
            "      if (table_[i].state == Empty) return nullptr;",
            "      if (table_[i].state == Occupied && table_[i].key == k) return &table_[i].val;",
            "    }",
            "  }",
            "",
            "  bool insert(const K& k, const V& v) {",
            "    if (size_ >= N * 3 / 4) return false;",
            "    for (auto i = hash(k);; i = (i + 1) & (N - 1)) {",
            "      if (table_[i].state != Occupied) {",
            "        table_[i] = {k, v, Occupied};",
            "        ++size_;",
            "        return true;",
            "      }",
            "      if (table_[i].key == k) { table_[i].val = v; return true; }",
            "    }",
            "  }",
            "  $0",
            "};"
        ]
    },
