    "benchscopedtimer": {
        "prefix": "benchscopedtimer",
        "description": "RAII scoped timer using steady_clock",
        "body": [
            "// scoped_timer.h — Production ScopedTimer for C++20 on Linux x86-64",
            "//",
            "// Usage:",
            "//   { SCOPED_TIMER(\"hot_path\"); do_stuff(); }                    // default:",
            "//   ns { SCOPED_TIMER_US(\"hot_path\"); do_stuff(); }                 //",
            "//   microseconds { SCOPED_TIMER_MS(\"hot_path\"); do_stuff(); } // milliseconds",
            "//   { SCOPED_TIMER_S(\"hot_path\"); do_stuff(); }                  // seconds",
            "//   { auto t = make_scoped_timer<TimeUnit::us>(\"x\"); do_stuff(); }",
            "//",
            "// Output (stderr):",
            "//   hot_path: 1,423,456 ns",
            "//   hot_path: 1,423.456 us",
            "//   hot_path: 1.423 ms",
            "//   hot_path: 0.001423456 s",
            "",
            "#pragma once",
            "",
            "#include <chrono>",
            "#include <cstddef>",
            "#include <cstdio>",
            "",
            "enum class TimeUnit : unsigned char { ns, us, ms, s };",
            "",
            "namespace detail {",
            "",
            "// Comma-format a non-negative integer into buf (null-terminated).",
            "// Returns pointer to buf. buf must be at least 32 bytes.",
            "inline char*",
            "comma_format_u64(char* buf, std::size_t bufsz, unsigned long long val) noexcept",
            "{",
            "    // Write digits right-to-left into scratch area.",
            "    char raw[21];  // max 20 digits for 2^64-1",
            "    int  len = 0;",
            "    if (val == 0) {",
            "        raw[len++] = '0';",
            "    }",
            "    else {",
            "        while (val > 0) {",
            "            raw[len++] = static_cast<char>('0' + val % 10);",
            "            val /= 10;",
            "        }",
            "    }",
            "",
            "    // Build output with commas, most-significant digit first.",
            "    char* p   = buf;",
            "    char* end = buf + bufsz - 1;",
            "    for (int i = len - 1; i >= 0 && p < end; --i) {",
            "        *p++ = raw[i];",
            "        if (i > 0 && i % 3 == 0 && p < end)",
            "            *p++ = ',';",
            "    }",
            "    *p = '\\0';",
            "    return buf;",
            "}",
            "",
            "// Format a nanosecond count (non-negative) into buf as the requested unit.",
            "// Returns pointer to buf.",
            "inline const char* format_duration(char*       buf,",
            "                                   std::size_t bufsz,",
            "                                   long long   ns,",
            "                                   TimeUnit    unit) noexcept",
            "{",
            "    // Negative durations should not occur with steady_clock, but clamp",
            "    // defensively rather than producing garbled output.",
            "    const auto abs_ns = static_cast<unsigned long long>(ns < 0 ? 0 : ns);",
            "    char       int_buf[32];",
            "",
            "    switch (unit) {",
            "    case TimeUnit::ns:",
            "        comma_format_u64(int_buf, sizeof(int_buf), abs_ns);",
            "        std::snprintf(buf, bufsz, \"%s ns\", int_buf);",
            "        break;",
            "    case TimeUnit::us:",
            "        comma_format_u64(int_buf, sizeof(int_buf), abs_ns / 1'000);",
            "        std::snprintf(buf, bufsz, \"%s.%03llu us\", int_buf, abs_ns % 1'000);",
            "        break;",
            "    case TimeUnit::ms:",
            "        comma_format_u64(int_buf, sizeof(int_buf), abs_ns / 1'000'000);",
            "        std::snprintf(buf,",
            "                      bufsz,",
            "                      \"%s.%03llu ms\",",
            "                      int_buf,",
            "                      (abs_ns % 1'000'000) / 1'000);",
            "        break;",
            "    case TimeUnit::s:",
            "        comma_format_u64(int_buf, sizeof(int_buf), abs_ns / 1'000'000'000);",
            "        std::snprintf(buf,",
            "                      bufsz,",
            "                      \"%s.%09llu s\",",
            "                      int_buf,",
            "                      abs_ns % 1'000'000'000);",
            "        break;",
            "    }",
            "    return buf;",
            "}",
            "",
            "inline void compiler_barrier() noexcept",
            "{",
            "    asm volatile(\"\" ::: \"memory\");",
            "}",
            "",
            "}  // namespace detail",
            "",
            "template <TimeUnit Unit = TimeUnit::ns>",
            "struct ScopedTimer {",
            "    using Clock     = std::chrono::steady_clock;",
            "    using TimePoint = Clock::time_point;",
            "",
            "    const char* label_;",
            "    TimePoint   start_;",
            "",
            "    explicit ScopedTimer(const char* label) noexcept",
            "    : label_(label)",
            "    , start_(Clock::now())",
            "    {",
            "        detail::compiler_barrier();",
            "    }",
            "",
            "    ScopedTimer(const ScopedTimer&)            = delete;",
            "    ScopedTimer& operator=(const ScopedTimer&) = delete;",
            "    ScopedTimer(ScopedTimer&&)                 = delete;",
            "    ScopedTimer& operator=(ScopedTimer&&)      = delete;",
            "",
            "    ~ScopedTimer() noexcept",
            "    {",
            "        detail::compiler_barrier();",
            "        const auto stop = Clock::now();",
            "        const auto ns   = std::chrono::duration_cast<std::chrono::nanoseconds>(",
            "                              stop - start_)",
            "                              .count();",
            "        char       buf[64];",
            "        detail::format_duration(buf, sizeof(buf), ns, Unit);",
            "        std::fprintf(stderr, \"%s: %s\\n\", label_, buf);",
            "    }",
            "};",
            "",
            "// Factory function — [[nodiscard]] catches the missing-variable-name bug.",
            "template <TimeUnit Unit = TimeUnit::ns>",
            "[[nodiscard(",
            "    \"Timer destroyed immediately — did you forget the variable name?\")]]",
            "inline ScopedTimer<Unit> make_scoped_timer(const char* label) noexcept",
            "{",
            "    return ScopedTimer<Unit>(label);",
            "}",
            "",
            "// Convenience macros — auto-generate unique variable names per line.",
            "#define SCOPED_TIMER_CAT_(a, b) a##b",
            "#define SCOPED_TIMER_CAT(a, b) SCOPED_TIMER_CAT_(a, b)",
            "",
            "#define SCOPED_TIMER(label)                                                   \\",
            "    auto SCOPED_TIMER_CAT(_scoped_timer_,                                     \\",
            "                          __LINE__) = make_scoped_timer<TimeUnit::ns>(label)",
            "",
            "#define SCOPED_TIMER_US(label)                                                \\",
            "    auto SCOPED_TIMER_CAT(_scoped_timer_,                                     \\",
            "                          __LINE__) = make_scoped_timer<TimeUnit::us>(label)",
            "",
            "#define SCOPED_TIMER_MS(label)                                                \\",
            "    auto SCOPED_TIMER_CAT(_scoped_timer_,                                     \\",
            "                          __LINE__) = make_scoped_timer<TimeUnit::ms>(label)",
            "",
            "#define SCOPED_TIMER_S(label)                                                 \\",
            "    auto SCOPED_TIMER_CAT(_scoped_timer_,                                     \\",
            "                          __LINE__) = make_scoped_timer<TimeUnit::s>(label)",
            ""
        ],
        "description": "scopedtimer"
    },
    "spsc": {
        "prefix": "spsc",
        "description": "Lock-free SPSC ring buffer",
        "body": [
            "template <typename T, std::size_t N>",
            "class SPSCQueue {",
            "  static_assert((N & (N - 1)) == 0, \"N must be power of 2\");",
            "  alignas(64) std::atomic<std::size_t> head_{0};",
            "  alignas(64) std::atomic<std::size_t> tail_{0};",
            "  alignas(64) std::array<T, N> buf_;",
            "",
            " public:",
            "  bool try_push(const T& val) {",
            "    auto h = head_.load(std::memory_order_relaxed);",
            "    auto next = (h + 1) & (N - 1);",
            "    if (next == tail_.load(std::memory_order_acquire)) return false;",
            "    buf_[h] = val;",
            "    head_.store(next, std::memory_order_release);",
            "    return true;",
            "  }",
            "",
            "  bool try_pop(T& val) {",
            "    auto t = tail_.load(std::memory_order_relaxed);",
            "    if (t == head_.load(std::memory_order_acquire)) return false;",
            "    val = buf_[t];",
            "    tail_.store((t + 1) & (N - 1), std::memory_order_release);",
            "    return true;",
            "  }",
            "};",
            "$0"
        ]
    },
