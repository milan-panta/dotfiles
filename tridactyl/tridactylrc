colors --url https://raw.githubusercontent.com/llbn5866/tokyonight-tridactyl-theme/refs/heads/main/tokyonight.css tokyonight

set hintfiltermode vimperator-reflow
set hintnames numeric

unbind J
unbind K

bind J tabnext
bind K tabprev

bind --mode=ex <C-n>  ex.next_completion
bind --mode=ex <C-p>  ex.prev_completion
